<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pdd.mall.mapper.RefundRequestMapper">
    
    <resultMap id="BaseResultMap" type="com.pdd.mall.entity.RefundRequest">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="user_id" property="userId"/>
        <result column="refund_amount" property="refundAmount"/>
        <result column="refund_type" property="refundType"/>
        <result column="reason" property="reason"/>
        <result column="description" property="description"/>
        <result column="images" property="images"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    
    <insert id="insert" parameterType="com.pdd.mall.entity.RefundRequest" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO refund_request (
            order_id, user_id, refund_amount, refund_type, reason, 
            description, images, status, create_time, update_time
        ) VALUES (
            #{orderId}, #{userId}, #{refundAmount}, #{refundType}, #{reason},
            #{description}, #{images}, #{status}, #{createTime}, #{updateTime}
        )
    </insert>
    
    <select id="findByOrderId" resultMap="BaseResultMap">
        SELECT * FROM refund_request WHERE order_id = #{orderId} ORDER BY create_time DESC
    </select>
    
    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT * FROM refund_request WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>
    
    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM refund_request WHERE id = #{id}
    </select>
    
    <update id="update" parameterType="com.pdd.mall.entity.RefundRequest">
        UPDATE refund_request
        SET status = #{status}, update_time = #{updateTime}
        WHERE id = #{id}
    </update>
    
</mapper>
