<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pdd.mall.mapper.ChatGroupMapper">
    
    <resultMap id="ChatGroupResult" type="com.pdd.mall.entity.ChatGroup">
        <result column="group_id" property="groupId"/>
        <result column="group_no" property="groupNo"/>
        <result column="group_name" property="groupName"/>
        <result column="group_avatar" property="groupAvatar"/>
        <result column="group_notice" property="groupNotice"/>
        <result column="creator_id" property="creatorId"/>
        <result column="max_members" property="maxMembers"/>
        <result column="member_count" property="memberCount"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    
    <!-- 插入群聊 -->
    <insert id="insert" parameterType="com.pdd.mall.entity.ChatGroup" useGeneratedKeys="true" keyProperty="groupId">
        INSERT INTO chat_group (
            group_no, group_name, group_avatar, group_notice,
            creator_id, max_members, member_count, status,
            create_time, update_time
        ) VALUES (
            #{groupNo}, #{groupName}, #{groupAvatar}, #{groupNotice},
            #{creatorId}, #{maxMembers}, #{memberCount}, #{status},
            NOW(), NOW()
        )
    </insert>
    
    <!-- 根据 ID 查询 -->
    <select id="findById" parameterType="java.lang.Long" resultMap="ChatGroupResult">
        SELECT * FROM chat_group WHERE group_id = #{groupId}
    </select>
    
    <!-- 根据群号查询 -->
    <select id="findByGroupNo" parameterType="java.lang.String" resultMap="ChatGroupResult">
        SELECT * FROM chat_group WHERE group_no = #{groupNo}
    </select>
    
    <!-- 更新群聊信息 -->
    <update id="update" parameterType="com.pdd.mall.entity.ChatGroup">
        UPDATE chat_group
        <set>
            <if test="groupName != null">group_name = #{groupName},</if>
            <if test="groupAvatar != null">group_avatar = #{groupAvatar},</if>
            <if test="groupNotice != null">group_notice = #{groupNotice},</if>
            <if test="maxMembers != null">max_members = #{maxMembers},</if>
            <if test="memberCount != null">member_count = #{memberCount},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE group_id = #{groupId}
    </update>
    
    <!-- 更新成员数 -->
    <update id="updateMemberCount">
        UPDATE chat_group
        SET member_count = #{memberCount}, update_time = NOW()
        WHERE group_id = #{groupId}
    </update>
    
    <!-- 删除群聊 -->
    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM chat_group WHERE group_id = #{groupId}
    </delete>
    
    <!-- 查询用户加入的所有群聊 -->
    <select id="findUserGroups" parameterType="java.lang.Long" resultMap="ChatGroupResult">
        SELECT g.* FROM chat_group g
        INNER JOIN chat_session_member m ON g.group_id = REPLACE(m.session_id, 'group_', '')
        WHERE m.session_id LIKE 'group_%' AND m.user_id = #{userId}
        AND m.leave_time IS NULL
        AND g.status = 1
        ORDER BY g.create_time DESC
    </select>
    
    <!-- 查询群聊成员数 -->
    <select id="countMembers" parameterType="java.lang.Long" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM chat_session_member
        WHERE session_id = CONCAT('group_', #{groupId})
        AND leave_time IS NULL
    </select>
    
    <!-- 检查用户是否在群聊中 -->
    <select id="isMember" resultType="java.lang.Boolean">
        SELECT COUNT(*) > 0 FROM chat_session_member
        WHERE session_id = CONCAT('group_', #{groupId})
        AND user_id = #{userId}
        AND leave_time IS NULL
    </select>
    
</mapper>
