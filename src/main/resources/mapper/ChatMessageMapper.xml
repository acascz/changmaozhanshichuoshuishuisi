<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pdd.mall.mapper.ChatMessageMapper">
    <resultMap id="BaseResultMap" type="com.pdd.mall.entity.ChatMessage">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="from_type" property="fromType"/>
        <result column="content" property="content"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT * FROM chat_message WHERE user_id = #{userId} ORDER BY create_time ASC
    </select>

    <insert id="insert" parameterType="com.pdd.mall.entity.ChatMessage" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_message (user_id, from_type, content)
        VALUES (#{userId}, #{fromType}, #{content})
    </insert>
</mapper>
